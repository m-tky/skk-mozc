 #define SKK_DEBUG() FCITX_LOGC(::fcitx::skk_logcategory, Debug)
 
@@ -627,6 +628,23 @@ SkkState::SkkState(SkkEngine *engine, InputContext *ic)
     skk_context_set_auto_start_henkan_keywords(
         context, const_cast<gchar **>(AUTO_START_HENKAN_KEYWORDS),
         G_N_ELEMENTS(AUTO_START_HENKAN_KEYWORDS));
+
+    mozc_integration_ = std::make_unique<skk_mozc::MozcIntegration>(
+        context, skk_mozc::IntegrationOptions::fromEnv());
+    for (const auto &dict : engine_->dictionaries()) {
+        if (!skk_dict_get_read_only(dict.get())) {
+            mozc_integration_->setUserDict(dict.get());
+            break;
+        }
+    }
+    // Hand the integration a live accessor for the engine's dict vector so
+    // it can run lookups across both user and system dictionaries before
+    // libskk consumes a SPC press.
+    mozc_integration_->setDictAccessor([eng = engine_]() {
+        std::vector<SkkDict *> v;
+        for (const auto &d : eng->dictionaries()) v.push_back(d.get());
+        return v;
+    });
 }
 
