diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index 5a84eaa..2976a0b 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -1,12 +1,64 @@
 
+find_package(Protobuf REQUIRED)
+# Modern protobuf (>= 22) requires absl. pkg-config gives the full link line
+# (libprotobuf + absl_log + absl_strings + ...) which the CMake imported
+# target alone doesn't transitively expose for MODULE libraries.
+find_package(PkgConfig REQUIRED)
+pkg_check_modules(SKK_MOZC_PROTOBUF REQUIRED IMPORTED_TARGET protobuf)
+
+set(SKK_MOZC_PROTO_DIR "${CMAKE_CURRENT_SOURCE_DIR}/proto")
+file(MAKE_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/protocol")
+file(MAKE_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/ipc")
+
+set(SKK_MOZC_PROTO_FILES
+    protocol/commands.proto
+    protocol/candidate_window.proto
+    protocol/config.proto
+    protocol/engine_builder.proto
+    protocol/user_dictionary_storage.proto
+    protocol/renderer_command.proto
+    protocol/renderer_style.proto
+    ipc/ipc.proto
+)
+
+set(SKK_MOZC_PROTO_SRCS)
+foreach(P ${SKK_MOZC_PROTO_FILES})
+    get_filename_component(DIR ${P} DIRECTORY)
+    get_filename_component(BASE ${P} NAME_WE)
+    set(OUT_CC "${CMAKE_CURRENT_BINARY_DIR}/${DIR}/${BASE}.pb.cc")
+    set(OUT_H  "${CMAKE_CURRENT_BINARY_DIR}/${DIR}/${BASE}.pb.h")
+    add_custom_command(
+        OUTPUT  ${OUT_CC} ${OUT_H}
+        COMMAND ${Protobuf_PROTOC_EXECUTABLE}
+                --cpp_out=${CMAKE_CURRENT_BINARY_DIR}
+                -I${SKK_MOZC_PROTO_DIR}
+                ${SKK_MOZC_PROTO_DIR}/${P}
+        DEPENDS ${SKK_MOZC_PROTO_DIR}/${P}
+        COMMENT "protoc ${P}")
+    list(APPEND SKK_MOZC_PROTO_SRCS ${OUT_CC})
+endforeach()
+
 set(SKK_SOURCES
     skk.cpp
+    mozc_client/mozc_client.cpp
+    mozc_client/ipc_socket.cpp
+    candidate_merger/merger.cpp
+    bunsetsu/refiner.cpp
+    log/log.cpp
+    panel_dispatch/panel_dispatch.cpp
+    skk_integration/mozc_integration.cpp
+    skk_integration/yomi_extract.cpp
+    ${SKK_MOZC_PROTO_SRCS}
 )
 add_fcitx5_addon(skk ${SKK_SOURCES})
+target_include_directories(skk PRIVATE
+    "${CMAKE_CURRENT_SOURCE_DIR}"
+    "${CMAKE_CURRENT_BINARY_DIR}")
 target_link_libraries(skk
     Fcitx5::Core
     Fcitx5::Config
     LibSKK::LibSKK
+    PkgConfig::SKK_MOZC_PROTOBUF
 )
 set_target_properties(skk PROPERTIES PREFIX "")
 install(TARGETS skk DESTINATION "${CMAKE_INSTALL_LIBDIR}/fcitx5")
diff --git a/src/skk.cpp b/src/skk.cpp
index 19b564b..115860c 100644
--- a/src/skk.cpp
+++ b/src/skk.cpp
@@ -48,6 +48,7 @@
 #include <glib-object.h>
 #include <glib.h>
 #include <libskk/libskk.h>
+#include "skk_integration/mozc_integration.h"
 
 #define SKK_DEBUG() FCITX_LOGC(::fcitx::skk_logcategory, Debug)
 
@@ -627,6 +628,51 @@ SkkState::SkkState(SkkEngine *engine, InputContext *ic)
     skk_context_set_auto_start_henkan_keywords(
         context, const_cast<gchar **>(AUTO_START_HENKAN_KEYWORDS),
         G_N_ELEMENTS(AUTO_START_HENKAN_KEYWORDS));
+
+    mozc_integration_ = std::make_unique<skk_mozc::MozcIntegration>(
+        context, skk_mozc::IntegrationOptions::fromEnv());
+    for (const auto &dict : engine_->dictionaries()) {
+        if (!skk_dict_get_read_only(dict.get())) {
+            mozc_integration_->setUserDict(dict.get());
+            break;
+        }
+    }
+    // Hand the integration a live accessor for the engine's dict vector so
+    // it can run lookups across both user and system dictionaries before
+    // libskk consumes a SPC press.
+    mozc_integration_->setDictAccessor([eng = engine_]() {
+        std::vector<SkkDict *> v;
+        for (const auto &d : eng->dictionaries()) v.push_back(d.get());
+        return v;
+    });
+    // After we commit a mozc-merged candidate we need SkkState's cached
+    // preedit_ cleared too, not just libskk's own state — otherwise the
+    // very next updateUI() pushes the stale ▽yomi back onto the input panel
+    // and the user sees their just-committed text plus the ghost preedit.
+    mozc_integration_->setFullReset([this]() { this->reset(); });
+
+    // Honour the user's CandidateChooseKey / PageSize from skk.conf so our
+    // panel feels identical to upstream fcitx5-skk's.
+    mozc_integration_->setConfigAccessor([eng = engine_]() {
+        skk_mozc::MozcIntegration::SkkConfigSnapshot snap;
+        snap.page_size = *eng->config().pageSize;
+        switch (*eng->config().candidateChooseKey) {
+        case CandidateChooseKey::ABC:
+            snap.choose_key = skk_mozc::MozcIntegration::
+                                  CandidateChooseKeyStyle::ABC;
+            break;
+        case CandidateChooseKey::Qwerty:
+            snap.choose_key = skk_mozc::MozcIntegration::
+                                  CandidateChooseKeyStyle::Qwerty;
+            break;
+        case CandidateChooseKey::Digit:
+        default:
+            snap.choose_key = skk_mozc::MozcIntegration::
+                                  CandidateChooseKeyStyle::Digit;
+            break;
+        }
+        return snap;
+    });
 }
 
