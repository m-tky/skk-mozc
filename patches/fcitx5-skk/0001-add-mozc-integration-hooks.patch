diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index 5a84eaa..597d789 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -1,12 +1,31 @@
 
+find_package(Protobuf REQUIRED)
+
+set(SKK_MOZC_PROTO_DIR "${CMAKE_CURRENT_SOURCE_DIR}/proto")
+file(MAKE_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/proto")
+
+protobuf_generate_cpp(SKK_MOZC_PROTO_SRCS SKK_MOZC_PROTO_HDRS
+    "${SKK_MOZC_PROTO_DIR}/commands.proto"
+    "${SKK_MOZC_PROTO_DIR}/config.proto")
+
 set(SKK_SOURCES
     skk.cpp
+    mozc_client/mozc_client.cpp
+    mozc_client/ipc_socket.cpp
+    candidate_merger/merger.cpp
+    bunsetsu/refiner.cpp
+    skk_integration/mozc_integration.cpp
+    ${SKK_MOZC_PROTO_SRCS}
 )
 add_fcitx5_addon(skk ${SKK_SOURCES})
+target_include_directories(skk PRIVATE
+    "${CMAKE_CURRENT_SOURCE_DIR}"
+    "${CMAKE_CURRENT_BINARY_DIR}")
 target_link_libraries(skk
     Fcitx5::Core
     Fcitx5::Config
     LibSKK::LibSKK
+    ${Protobuf_LIBRARIES}
 )
 set_target_properties(skk PROPERTIES PREFIX "")
 install(TARGETS skk DESTINATION "${CMAKE_INSTALL_LIBDIR}/fcitx5")
@@ -18,3 +37,17 @@ install(FILES "${CMAKE_CURRENT_BINARY_DIR}/skk-addon.conf" RENAME skk.conf DESTI
 
 configure_file(${CMAKE_CURRENT_SOURCE_DIR}/dictionary_list.in ${CMAKE_CURRENT_BINARY_DIR}/dictionary_list @ONLY)
 install(FILES ${CMAKE_CURRENT_BINARY_DIR}/dictionary_list DESTINATION "${FCITX_INSTALL_PKGDATADIR}/skk")
+
+option(SKK_MOZC_BUILD_CLI "Also build mozc-client-cli" OFF)
+if(SKK_MOZC_BUILD_CLI)
+    add_executable(mozc-client-cli
+        mozc_client/cli_main.cpp
+        mozc_client/mozc_client.cpp
+        mozc_client/ipc_socket.cpp
+        ${SKK_MOZC_PROTO_SRCS})
+    target_include_directories(mozc-client-cli PRIVATE
+        "${CMAKE_CURRENT_SOURCE_DIR}"
+        "${CMAKE_CURRENT_BINARY_DIR}")
+    target_link_libraries(mozc-client-cli ${Protobuf_LIBRARIES})
+    install(TARGETS mozc-client-cli DESTINATION "${CMAKE_INSTALL_BINDIR}")
+endif()
