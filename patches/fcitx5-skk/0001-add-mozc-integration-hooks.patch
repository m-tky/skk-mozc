diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index 5a84eaa..da63581 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -1,12 +1,63 @@
 
+find_package(Protobuf REQUIRED)
+# Modern protobuf (>= 22) requires absl. pkg-config gives the full link line
+# (libprotobuf + absl_log + absl_strings + ...) which the CMake imported
+# target alone doesn't transitively expose for MODULE libraries.
+find_package(PkgConfig REQUIRED)
+pkg_check_modules(SKK_MOZC_PROTOBUF REQUIRED IMPORTED_TARGET protobuf)
+
+set(SKK_MOZC_PROTO_DIR "${CMAKE_CURRENT_SOURCE_DIR}/proto")
+file(MAKE_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/protocol")
+file(MAKE_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/ipc")
+
+set(SKK_MOZC_PROTO_FILES
+    protocol/commands.proto
+    protocol/candidate_window.proto
+    protocol/config.proto
+    protocol/engine_builder.proto
+    protocol/user_dictionary_storage.proto
+    protocol/renderer_command.proto
+    protocol/renderer_style.proto
+    ipc/ipc.proto
+)
+
+set(SKK_MOZC_PROTO_SRCS)
+foreach(P ${SKK_MOZC_PROTO_FILES})
+    get_filename_component(DIR ${P} DIRECTORY)
+    get_filename_component(BASE ${P} NAME_WE)
+    set(OUT_CC "${CMAKE_CURRENT_BINARY_DIR}/${DIR}/${BASE}.pb.cc")
+    set(OUT_H  "${CMAKE_CURRENT_BINARY_DIR}/${DIR}/${BASE}.pb.h")
+    add_custom_command(
+        OUTPUT  ${OUT_CC} ${OUT_H}
+        COMMAND ${Protobuf_PROTOC_EXECUTABLE}
+                --cpp_out=${CMAKE_CURRENT_BINARY_DIR}
+                -I${SKK_MOZC_PROTO_DIR}
+                ${SKK_MOZC_PROTO_DIR}/${P}
+        DEPENDS ${SKK_MOZC_PROTO_DIR}/${P}
+        COMMENT "protoc ${P}")
+    list(APPEND SKK_MOZC_PROTO_SRCS ${OUT_CC})
+endforeach()
+
 set(SKK_SOURCES
     skk.cpp
+    mozc_client/mozc_client.cpp
+    mozc_client/ipc_socket.cpp
+    candidate_merger/merger.cpp
+    bunsetsu/refiner.cpp
+    log/log.cpp
+    panel_dispatch/panel_dispatch.cpp
+    skk_integration/mozc_integration.cpp
+    ${SKK_MOZC_PROTO_SRCS}
 )
 add_fcitx5_addon(skk ${SKK_SOURCES})
+target_include_directories(skk PRIVATE
+    "${CMAKE_CURRENT_SOURCE_DIR}"
+    "${CMAKE_CURRENT_BINARY_DIR}")
 target_link_libraries(skk
     Fcitx5::Core
     Fcitx5::Config
     LibSKK::LibSKK
+    PkgConfig::SKK_MOZC_PROTOBUF
 )
 set_target_properties(skk PROPERTIES PREFIX "")
 install(TARGETS skk DESTINATION "${CMAKE_INSTALL_LIBDIR}/fcitx5")
